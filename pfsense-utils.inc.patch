+        $free = disk_free_space("/");
+        $total = disk_total_space("/");
+        $used = $total - $free;
+        $perc = round($used * 100 / $total);
+        return [bytes_prefix($total),bytes_prefix($used),bytes_prefix($free),$perc."%"];
 }
 
