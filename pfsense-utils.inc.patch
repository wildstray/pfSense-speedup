+function bytes_prefix($bytes) {
+    $si_prefix = array( '', 'K', 'M', 'G', 'T', 'E', 'Z', 'Y' );
+    $base = 1024;
+    $class = min((int)log($bytes , $base) , count($si_prefix) - 1);
+    return sprintf('%1.0f' , $bytes / pow($base,$class)) . $si_prefix[$class];
+}
