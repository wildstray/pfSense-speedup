+function get_ifconfig_all() {
+    static $data = null;
+    if ($data === null) {
+        $data = [];
+        exec("/sbin/ifconfig -a", $raw, $rc);
+        if ($rc != 0) return $data;
+
+        $current = null;
+        foreach ($raw as $line) {
+            if (preg_match('/^(\S+):/', $line, $m)) {
+                $current = $m[1];
+                $data[$current] = [
+                    'raw'    => [],
+                    'media'  => null,
+                    'status' => null,
+                    'mtu'    => null,
+                    'ether'  => null,
+                    'descr'  => null,
+                    'inet'   => [],
+                    'inet6'  => [],
+                    'groups' => [],
+                    'channel'    => null,
+                    'ssid'       => null,
+                    'bssid'      => null,
+                    'rate'       => null,
+                    'rssi'       => null,
+                    'laggproto'  => null,
+                    'laggport'   => [],
+                    'plugged'    => null,
+                    'vendor'     => null,
+                    'temperature'=> null,
+                    'voltage'    => null,
+                    'rx'         => null,
+                    'tx'         => null,
+                ];
+                if (preg_match('/mtu (\d+)/', $line, $mm)) {
+                    $data[$current]['mtu'] = (int)$mm[1];
+                }
+                continue;
+            }
+            if ($current === null) continue;
+
+            $l = ltrim($line);
+            $data[$current]['raw'][] = $l;
+
+            if (preg_match('/^description:\s+(.+)$/', $l, $m)) {
+                $data[$current]['descr'] = $m[1];
+            } elseif (preg_match('/^ether\s+(\S+)/', $l, $m)) {
+                $data[$current]['ether'] = $m[1];
+            } elseif (preg_match('/^inet6\s+(\S+)\s+prefixlen\s+(\d+)/', $l, $m)) {
+                $addr = $m[1];
+                // rimuovi %iface dal link-local
+                if (($pos = strpos($addr, '%')) !== false) {
+                    $addr = substr($addr, 0, $pos);
+                }
+                $data[$current]['inet6'][] = [
+                    'address'  => $addr,
+                    'prefixlen'=> (int)$m[2],
+                ];
+            } elseif (preg_match('/^inet\s+(\S+)\s+netmask\s+(\S+)(?:\s+broadcast\s+(\S+))?/', $l, $m)) {
+                $data[$current]['inet'][] = [
+                    'address'   => $m[1],
+                    'netmask'   => $m[2],
+                    'broadcast' => $m[3] ?? null,
+                ];
+            } elseif (preg_match('/^status:\s+(.+)$/', $l, $m)) {
+                $data[$current]['status'] = $m[1];
+            } elseif (preg_match('/^media:\s+.*?\((.*?)\)/', $l, $m)) {
+                $data[$current]['media'] = $m[1];
+            } elseif (preg_match('/^media:\s+Ethernet\s+(.+)$/', $l, $m)) {
+                $data[$current]['media'] = $m[1];
+            } elseif (preg_match('/^media:\s+IEEE 802\.11 Wireless Ethernet\s+(.+)$/', $l, $m)) {
+                $data[$current]['media'] = $m[1];
+            } elseif (preg_match('/^groups:\s+(.+)$/', $l, $m)) {
+                $data[$current]['groups'] = explode(' ', trim($m[1]));
+            } elseif (preg_match('/^channel\s+(\S+)/', $l, $m)) {
+                $data[$current]['channel'] = $m[1];
+            } elseif (preg_match('/^ssid\s+(\".*?\"|\S+)/', $l, $m)) {
+                $ssid = $m[1];
+                $data[$current]['ssid'] = ($ssid[0] === '"') ? substr($ssid, 1, -1) : $ssid;
+            } elseif (preg_match('/^laggproto\s+(.+)$/', $l, $m)) {
+                $data[$current]['laggproto'] = $m[1];
+            } elseif (preg_match('/^laggport:\s+(.+)$/', $l, $m)) {
+                $data[$current]['laggport'][] = $m[1];
+            } elseif (preg_match('/^plugged:\s+(.+)$/', $l, $m)) {
+                $data[$current]['plugged'] = $m[1];
+            } elseif (preg_match('/^vendor:\s+(.+)$/', $l, $m)) {
+                $data[$current]['vendor'] = $m[1];
+            } elseif (preg_match('/^module temperature:\s+(.*)\s+Voltage:\s+(.+)$/', $l, $m)) {
+                $data[$current]['temperature'] = $m[1];
+                $data[$current]['voltage']     = $m[2];
+            } elseif (preg_match('/^RX:\s+(.*)\s+TX:\s+(.+)$/', $l, $m)) {
+                $data[$current]['rx'] = $m[1];
+                $data[$current]['tx'] = $m[2];
+            }
+        }
+    }
+    return $data;
+}
